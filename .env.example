# ============================================================================
# B2B Lead Generation & Enrichment Engine - Environment Configuration
# ============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env (Git will ignore it automatically)
# 2. Add your actual API key to the GEMINI_API_KEY value below
# 3. The system will load this during local development
# 4. In production/browser, the system uses localStorage instead
#
# NEVER commit your actual .env file with real API keys to version control
#

# Google Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Default configuration for development
DEFAULT_NICHE=High-Ticket B2B Coaching
DEFAULT_TARGET_LEADS=50