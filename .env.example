# ============================================================================
# B2B Lead Generation & Enrichment Engine - Backend Server Configuration
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env  (Git will ignore it automatically)
# 2. Adjust values as needed — all variables are optional
# 3. Authenticate with Google Cloud before starting the server:
#
#    Option A — Developer workstation (recommended for local dev):
#      gcloud auth application-default login
#
#    Option B — Service account key file:
#      Set GOOGLE_APPLICATION_CREDENTIALS to the path of your JSON key file
#
#    Option C — Running on Google Cloud (Cloud Run, GCE, GKE, etc.):
#      No action needed — ADC is picked up automatically from the instance
#      metadata service.
#
# NEVER commit your actual .env file to version control.
#

# ── Server ───────────────────────────────────────────────────────────────────
# HTTP port the backend listens on (default: 3000)
PORT=3000

# ── Gemini Model ─────────────────────────────────────────────────────────────
# Gemini model to use for lead generation (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Google Cloud Auth (service account) ──────────────────────────────────────
# Path to a service-account JSON key file.
# Leave unset when using `gcloud auth application-default login` or running
# on a Google Cloud compute environment (Cloud Run, GCE, etc.).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Optional defaults for the frontend ───────────────────────────────────────
DEFAULT_NICHE=High-Ticket B2B Coaching
DEFAULT_TARGET_LEADS=50
